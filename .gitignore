# SAGE Framework: Data-Free .gitignore

# 1. Exclude all CSV and JSON data dumps (The "Data-Free" Rule)
*.csv
*.json
*.hdf5
*.log

# 2. Exclude large binary and local files
/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
env/
dist/
build/
*.egg-info/
.DS_Store

# 3. Exclude internal dev files and local archives
99_archives/
(not for github)/
.vscode/
.antigravity/
.gemini/

# 4. White-list specific required config files (if any)
!CONSCIOUSNESS_MANIFEST.json
